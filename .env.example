# ─── Flask API ───────────────────────────────────────────────────────────────
API_KEY=change_me_to_a_random_32char_string

# URL the API is reachable at (used in email links, etc.)
# e.g. https://api.yourdomain.com
API_BASE_URL=https://api.yourdomain.com

# CORS — set to your Vercel frontend URL
ALLOWED_ORIGIN=https://jobappagent.vercel.app

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_DOMAIN=n8n.yourdomain.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password
N8N_WEBHOOK_SECRET=change_me_webhook_secret

# ─── Postgres (n8n database) ─────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_db_password

# ─── AI provider (pick one) ──────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# OPENROUTER_API_KEY=
# TOGETHER_API_KEY=

# ─── Email ───────────────────────────────────────────────────────────────────
REVIEW_RECIPIENT_EMAIL=your@email.com

EMAIL_PROVIDER=smtp          # smtp | sendgrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password  # Gmail: use App Password, not account password
SMTP_FROM=your@gmail.com

# SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=
# SENDGRID_FROM=

# ─── Reddit (optional scraper) ───────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=jobhunterke/1.0
